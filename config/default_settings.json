{
    "ollama": {
        "host": "http://localhost:11434",
        "timeout": 120,
        "auto_start": false
    },
    "model_defaults": {
        "temperature": 0.7,
        "top_p": 0.9,
        "top_k": 40,
        "repeat_penalty": 1.1,
        "num_ctx": 4096,
        "num_gpu": -1
    },
    "ui": {
        "theme": "dark",
        "font_size": 14,
        "window_width": 1200,
        "window_height": 800
    },
    "paths": {
        "models_dir": "~/ai-models",
        "gguf_extensions": [".gguf", ".bin"]
    },
    "chat": {
        "max_context_messages": 40
    },
    "translation": {
        "enabled": true,
        "source_lang": "es",
        "target_lang": "en",
        "auto_translate_input": true
    }
}
